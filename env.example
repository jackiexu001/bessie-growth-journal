# 存储类型（生产环境必须设置为 cos）
STORAGE_TYPE=cos

# ============================================
# 腾讯云 COS 配置
# 在腾讯云控制台 -> 对象存储 -> Bucket 列表 中获取
# ============================================

# API 密钥：在 访问管理 -> API密钥管理 中创建
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key

# Bucket 名称（格式：BucketName-APPID，例如 bessie-1234567890）
COS_BUCKET_NAME=your_bucket_name-appid

# 地域（轻量服务器所在地域，例如 ap-guangzhou、ap-beijing、ap-shanghai）
COS_REGION=ap-guangzhou

# Bucket 公开访问地址（可选，不填则自动生成）
# 格式：https://<BucketName-APPID>.cos.<Region>.myqcloud.com
# COS_PUBLIC_URL=https://your_bucket_name-appid.cos.ap-guangzhou.myqcloud.com
